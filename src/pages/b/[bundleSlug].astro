    }
    if (urlLower.includes("skeb.jp")) {
        return `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 17.894l-2.12-2.12a5.5 5.5 0 11-7.55-7.55l-2.12-2.12a8.5 8.5 0 1011.79 11.79z"/></svg>`;
    }
    if (urlLower.includes("line.me")) {
        return `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.631-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>`;
    }
    if (urlLower.includes("vk.com")) {
        return `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M15.684 0H8.316C1.592 0 0 1.592 0 8.316v7.368C0 22.408 1.592 24 8.316 24h7.368C22.408 24 24 22.408 24 15.684V8.316C24 1.592 22.408 0 15.684 0zm3.692 17.123h-1.744c-.66 0-.864-.525-2.05-1.727-1.033-1-1.49-1.135-1.744-1.135-.356 0-.458.102-.458.593v1.575c0 .424-.135.678-1.253.678-1.846 0-3.896-1.118-5.335-3.202C4.624 10.857 4.03 8.57 4.03 8.096c0-.254.102-.491.593-.491h1.744c.44 0 .61.203.78.677.847 2.457 2.27 4.607 2.85 4.607.22 0 .322-.102.322-.66V9.721c-.068-1.186-.695-1.287-.695-1.71 0-.204.17-.407.44-.407h2.744c.373 0 .508.203.508.643v3.473c0 .372.17.508.271.508.22 0 .407-.136.813-.542 1.254-1.406 2.151-3.574 2.151-3.574.119-.254.322-.491.763-.491h1.744c.525 0 .644.27.525.643-.22 1.017-2.354 4.031-2.354 4.031-.186.305-.254.44 0 .78.186.254.796.779 1.203 1.253.745.847 1.32 1.558 1.473 2.05.17.49-.085.744-.576.744z"/></svg>`;
    }
    if (urlLower.includes("reddit.com")) {
        return `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>`;
    }
    if (urlLower.includes("patreon.com")) {
        return `<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 .48v23.04h4.22V.48zm15.385 0c-4.764 0-8.641 3.88-8.641 8.65 0 4.755 3.877 8.623 8.641 8.623 4.75 0 8.615-3.868 8.615-8.623C24 4.36 20.136.48 15.385.48z"/></svg>`;
    }

    // Return null for unknown - will use favicon instead
    return null;
};

// If bundle not found, redirect to home
if (!bundle) {
    return Astro.redirect("/?error=not_found");
}
---

<html lang={lang}>
    <head>
        <SEO
            title={`${bundle.title} | rsh.pw`}
            description={bundle.description ||
                `${bundle.title} - Link collection on rsh.pw`}
            image={avatarUrl || "/favicon.svg"}
            type="profile"
        />
        <style>
            @keyframes gradient {
                0% {
                    background-position: 0% 50%;
                }
                50% {
                    background-position: 100% 50%;
                }
                100% {
                    background-position: 0% 50%;
                }
            }
            .animate-gradient {
                background-size: 200% 200%;
                animation: gradient 15s ease infinite;
            }
            @keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            .animate-fade-in-up {
                animation: fadeInUp 0.5s ease forwards;
            }
            .link-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
            }
            .highlighted-link {
                position: relative;
                overflow: visible !important;
            }
            .highlighted-link::before {
                content: "";
                position: absolute;
                inset: -2px;
                background: linear-gradient(45deg, #9333ea, #db2777, #9333ea);
                background-size: 200% 200%;
                border-radius: inherit;
                z-index: -1;
                animation: gradient 3s linear infinite;
                opacity: 0.6;
            }
        </style>
    </head>
    <body
        class={`${bgStyle === "gradient" ? bgClass : "bg-gray-900"} text-white min-h-screen font-sans antialiased selection:bg-cyan-500 selection:text-white ${bgStyle === "mesh" ? "mesh-bg" : ""}`}
        style={bgStyle === "gradient"
            ? "background-size: 400% 400%; animation: gradient 15s ease infinite;"
            : ""}
    >
        <!-- Back button -->
        <div class="absolute top-4 left-4">
            <a
                href="/"
                class="text-gray-400 hover:text-white transition-colors flex items-center gap-2"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                <span class="text-sm hidden sm:inline">rsh.pw</span>
            </a>
        </div>

        <!-- Top controls -->
        <div class="absolute top-4 right-4 flex items-center gap-2">
            <button
                id="qr-btn"
                class="text-gray-400 hover:text-white transition-colors p-2 rounded-lg hover:bg-gray-800/50"
                title={t.qr_code || "QR Code"}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><rect x="3" y="3" width="7" height="7"></rect><rect
                        x="14"
                        y="3"
                        width="7"
                        height="7"></rect><rect
                        x="14"
                        y="14"
                        width="7"
                        height="7"></rect><path d="M3 14h7v7H3z"></path></svg
                >
            </button>
            <a
                id="edit-btn"
                href={`/b/${bundleSlug}/edit`}
                class="hidden text-gray-400 hover:text-white transition-colors flex items-center gap-2"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path
                        d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
                    ></path>
                    <path
                        d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
                    ></path>
                </svg>
                <span class="text-sm hidden sm:inline">{t.edit || "Edit"}</span>
            </a>
        </div>

        <main
            class="w-full max-w-lg mx-auto px-6 py-16 flex flex-col items-center gap-8"
        >
            <!-- Profile Section -->
            <div
                class="text-center space-y-4 animate-fade-in-up"
                style="animation-delay: 0.1s;"
            >
                <!-- Avatar - Image or Fallback -->
                {
                    avatarUrl ? (
                        <div class="w-24 h-24 mx-auto rounded-full overflow-hidden shadow-lg ring-4 ring-gray-800 relative">
                            <img
                                id="avatar-img"
                                src={avatarUrl}
                                alt={bundle.title}
                                class="w-full h-full object-cover"
                                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                            />
                            <div
                                class={`w-full h-full bg-gradient-to-br ${themeGradient} animate-gradient items-center justify-center text-3xl font-bold absolute inset-0 hidden`}
                            >
                                {bundle.title.charAt(0).toUpperCase()}
                            </div>
                        </div>
                    ) : (
                        <div
                            class={`w-24 h-24 mx-auto rounded-full bg-gradient-to-br ${themeGradient} animate-gradient flex items-center justify-center text-3xl font-bold shadow-lg`}
                        >
                            {bundle.title.charAt(0).toUpperCase()}
                        </div>
                    )
                }

                <div class="space-y-2">
                    <h1 class="text-2xl font-bold text-white">
                        {bundle.title}
                    </h1>
                    {
                        bundle.description && (
                            <p class="text-gray-400 text-sm max-w-xs mx-auto">
                                {bundle.description}
                            </p>
                        )
                    }
                </div>
            </div>

            <!-- Links Section -->
            <div class="w-full space-y-3">
                {
                    links.map((link: any, index: number) => {
                        const socialIcon = getSocialIcon(link.url);
                        const faviconUrl = getFaviconUrl(link.url);

                        const isHighlighted = link.is_highlighted === 1;

                        return (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class={`link-card block w-full ${cardClass} ${buttonClass} p-4 transition-all duration-200 animate-fade-in-up group hover:scale-[1.02] ${isHighlighted ? "highlighted-link shadow-xl shadow-cyan-500/20" : ""}`}
                                style={`animation-delay: ${0.15 + index * 0.05}s; opacity: 0;`}
                            >
                                <div class="flex items-center gap-4 relative">
                                    {isHighlighted && (
                                        <div class="absolute -top-7 -left-2 flex items-center gap-1 px-2 py-0.5 bg-gray-900 border border-cyan-500/50 rounded-full shadow-lg">
                                            <span class="text-[10px] font-bold bg-gradient-to-r from-cyan-300 to-teal-400 bg-clip-text text-transparent uppercase tracking-tight">
                                                FEATURED
                                            </span>
                                            <svg
                                                class="w-2.5 h-2.5 text-cyan-400"
                                                fill="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                            </svg>
                                        </div>
                                    )}
                                    {socialIcon ? (
                                        <div
                                            class={`w-10 h-10 rounded-lg bg-gradient-to-br ${themeGradient} flex items-center justify-center text-white shrink-0`}
                                        >
                                            <Fragment set:html={socialIcon} />
                                        </div>
                                    ) : (
                                        <div class="w-10 h-10 rounded-lg bg-gray-700/50 flex items-center justify-center shrink-0 overflow-hidden">
                                            <img
                                                src={faviconUrl}
                                                alt=""
                                                class="w-6 h-6 object-contain"
                                                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                            />
                                            <div
                                                class={`w-full h-full bg-gradient-to-br ${themeGradient} items-center justify-center text-white hidden`}
                                            >
                                                <svg
                                                    class="w-5 h-5"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                >
                                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                                                </svg>
                                            </div>
                                        </div>
                                    )}
                                    <div class="flex-1 min-w-0">
                                        <div class="font-medium text-white group-hover:text-cyan-300 transition-colors truncate">
                                            {link.title}
                                        </div>
                                        <div class="text-xs text-gray-500 truncate">
                                            {new URL(link.url).hostname}
                                        </div>
                                    </div>
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="w-5 h-5 text-gray-500 group-hover:text-white transition-colors shrink-0"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                        <polyline points="15 3 21 3 21 9" />
                                        <line x1="10" y1="14" x2="21" y2="3" />
                                    </svg>
                                </div>
                            </a>
                        );
                    })
                }
            </div>

            <!-- Footer -->
            <footer
                class="text-center space-y-4 pt-8 animate-fade-in-up"
                style={`animation-delay: ${0.2 + links.length * 0.05}s; opacity: 0;`}
            >
                <a
                    href="/bundle"
                    class={`inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r ${themeGradient} text-white text-sm font-medium hover:opacity-90 transition-opacity`}
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    {t.create_own || "Create your own"}
                </a>

                <p class="text-gray-600 text-xs font-mono">
                    {t.powered_by || "Powered by"}
                    <a
                        href="/"
                        class="text-cyan-400 hover:text-cyan-300 transition-colors"
                        >rsh.pw</a
                    >
                </p>
            </footer>
        </main>

        <!-- QR Modal -->
        <div
            id="qr-modal"
            class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4 opacity-0 transition-opacity duration-300"
        >
            <div
                class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-sm p-6 shadow-2xl transform scale-95 transition-transform duration-300 max-h-[90vh] overflow-y-auto custom-scrollbar"
                id="qr-modal-content"
            >
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-white">
                        {t.qr_code || "QR Code"}
                    </h2>
                    <button
                        id="close-qr-modal"
                        class="text-gray-400 hover:text-white transition-colors"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="18" y1="6" x2="6" y2="18"></line><line
                                x1="6"
                                y1="6"
                                x2="18"
                                y2="18"></line></svg
                        >
                    </button>
                </div>

                <div class="flex flex-col items-center gap-6">
                    <div
                        id="qr-container"
                        class="bg-white p-4 rounded-xl shadow-inner flex justify-center"
                    >
                        <canvas id="qr-canvas"></canvas>
                    </div>

                    <!-- Customization -->
                    <div class="w-full space-y-4">
                        <h3
                            class="text-sm font-medium text-gray-400 uppercase tracking-wider"
                        >
                            {t.customize_qr || "Customize QR"}
                        </h3>

                        <!-- Logo -->
                        <div class="space-y-1">
                            <label class="text-xs text-gray-500 block"
                                >{t.qr_logo || "Logo URL"}</label
                            >
                            <input
                                type="url"
                                id="qr-logo"
                                placeholder={t.qr_logo_placeholder ||
                                    "https://example.com/logo.png"}
                                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-xs focus:outline-none focus:ring-2 focus:ring-cyan-500"
                            />
                        </div>

                        <!-- Style -->
                        <div class="space-y-1">
                            <label class="text-xs text-gray-500 block"
                                >{t.qr_dots_style || "Dots Style"}</label
                            >
                            <select
                                id="qr-style-select"
                                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-xs focus:outline-none focus:ring-2 focus:ring-cyan-500"
                            >
                                <option value="square"
                                    >{t.qr_style_square || "Square"}</option
                                >
                                <option value="dots"
                                    >{t.qr_style_dots || "Dots"}</option
                                >
                                <option value="rounded"
                                    >{t.qr_style_rounded || "Rounded"}</option
                                >
                                <option value="classy"
                                    >{t.qr_style_classy || "Classy"}</option
                                >
                                <option value="classy-rounded"
                                    >{
                                        t.qr_style_classy_rounded ||
                                            "Classy Rounded"
                                    }</option
                                >
                                <option value="extra-rounded"
                                    >{
                                        t.qr_corners_extra_rounded ||
                                            "Extra Rounded"
                                    }</option
                                >
                            </select>
                        </div>

                        <!-- Colors -->
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label
                                    for="qr-color"
                                    class="text-xs text-gray-500 block"
                                    >{t.qr_color || "Color"}</label
                                >
                                <div
                                    class="flex items-center gap-2 bg-gray-800 rounded-lg p-2 border border-gray-700"
                                >
                                    <input
                                        type="color"
                                        id="qr-color"
                                        value="#000000"
                                        class="w-6 h-6 rounded cursor-pointer bg-transparent border-0 p-0"
                                    />
                                    <span
                                        class="text-xs text-gray-400 font-mono"
                                        id="qr-color-value">#000000</span
                                    >
                                </div>
                            </div>
                            <div class="space-y-1">
                                <label
                                    for="qr-bg-color"
                                    class="text-xs text-gray-500 block"
                                    >{t.qr_bg_color || "Background"}</label
                                >
                                <div
                                    class="flex items-center gap-2 bg-gray-800 rounded-lg p-2 border border-gray-700"
                                >
                                    <input
                                        type="color"
                                        id="qr-bg-color"
                                        value="#ffffff"
                                        class="w-6 h-6 rounded cursor-pointer bg-transparent border-0 p-0"
                                    />
                                    <span
                                        class="text-xs text-gray-400 font-mono"
                                        id="qr-bg-color-value">#ffffff</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>

                    <button
                        id="download-qr"
                        class="w-full bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-500 hover:to-teal-500 text-white font-bold py-3 px-6 rounded-xl transition-all text-center flex items-center justify-center gap-2"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                            ></path><polyline points="7 10 12 15 17 10"
                            ></polyline><line x1="12" y1="15" x2="12" y2="3"
                            ></line></svg
                        >
                        {t.download_qr || "Download QR"}
                    </button>
                </div>
            </div>
        </div>

        <script>
            import QRCodeStyling from "qr-code-styling";

            const qrBtn = document.getElementById(
                "qr-btn",
            ) as HTMLButtonElement | null;
            const qrModal = document.getElementById(
                "qr-modal",
            ) as HTMLDivElement | null;
            const qrModalContent = document.getElementById(
                "qr-modal-content",
            ) as HTMLDivElement | null;
            const closeQrModal = document.getElementById(
                "close-qr-modal",
            ) as HTMLButtonElement | null;
            const qrContainer = document.getElementById(
                "qr-container",
            ) as HTMLDivElement | null;
            const downloadQrBtn = document.getElementById(
                "download-qr",
            ) as HTMLButtonElement | null;

            const qrColorInput = document.getElementById(
                "qr-color",
            ) as HTMLInputElement | null;
            const qrBgColorInput = document.getElementById(
                "qr-bg-color",
            ) as HTMLInputElement | null;
            const qrColorValue = document.getElementById(
                "qr-color-value",
            ) as HTMLElement | null;
            const qrBgColorValue = document.getElementById(
                "qr-bg-color-value",
            ) as HTMLElement | null;
            const qrLogoInput = document.getElementById(
                "qr-logo",
            ) as HTMLInputElement | null;
            const qrStyleSelect = document.getElementById(
                "qr-style-select",
            ) as HTMLSelectElement | null;

            let currentUrl = window.location.href;
            let qrCode: any;

            const initQR = () => {
                const options = {
                    width: 300,
                    height: 300,
                    type: "svg" as const,
                    data: currentUrl,
                    image: "",
                    dotsOptions: {
                        color: "#000000",
                        type: "square" as const,
                    },
                    backgroundOptions: {
                        color: "#ffffff",
                    },
                    imageOptions: {
                        crossOrigin: "anonymous",
                        margin: 10,
                    },
                };

                qrCode = new QRCodeStyling(options);

                if (qrContainer) {
                    qrContainer.innerHTML = "";
                    qrCode.append(qrContainer);
                }
            };

            const updateQR = () => {
                if (!qrCode) initQR();

                const color = qrColorInput ? qrColorInput.value : "#000000";
                const bgColor = qrBgColorInput
                    ? qrBgColorInput.value
                    : "#ffffff";
                const logo = qrLogoInput ? qrLogoInput.value : "";
                const style = qrStyleSelect ? qrStyleSelect.value : "square";

                // Update hex display
                if (qrColorValue) qrColorValue.textContent = color;
                if (qrBgColorValue) qrBgColorValue.textContent = bgColor;

                const dotType =
                    style === "rounded" ||
                    style === "dots" ||
                    style === "classy" ||
                    style === "classy-rounded" ||
                    style === "square" ||
                    style === "extra-rounded"
                        ? style
                        : "square";

                qrCode.update({
                    data: currentUrl,
                    dotsOptions: {
                        color: color,
                        type: dotType,
                    },
                    backgroundOptions: {
                        color: bgColor,
                    },
                    image: logo,
                });
            };

            const openModal = () => {
                if (!qrCode) initQR();
                else updateQR();

                if (qrModal && qrModalContent) {
                    qrModal.classList.remove("hidden");
                    setTimeout(() => {
                        qrModal.classList.remove("opacity-0");
                        qrModalContent.classList.remove("scale-95");
                        qrModalContent.classList.add("scale-100");
                    }, 10);
                }
            };

            const closeModal = () => {
                if (qrModal && qrModalContent) {
                    qrModal.classList.add("opacity-0");
                    qrModalContent.classList.remove("scale-100");
                    qrModalContent.classList.add("scale-95");
                    setTimeout(() => {
                        qrModal.classList.add("hidden");
                    }, 300);
                }
            };

            // Event Listeners
            if (qrBtn) qrBtn.addEventListener("click", openModal);
            if (closeQrModal)
                closeQrModal.addEventListener("click", closeModal);
            if (qrModal) {
                qrModal.addEventListener("click", (e) => {
                    if (e.target === qrModal) closeModal();
                });
            }

            const inputs = [
                qrColorInput,
                qrBgColorInput,
                qrLogoInput,
                qrStyleSelect,
            ];
            inputs.forEach((input) => {
                if (input) {
                    input.addEventListener("input", updateQR);
                    input.addEventListener("change", updateQR);
                }
            });

            if (downloadQrBtn) {
                downloadQrBtn.addEventListener("click", () => {
                    if (qrCode) {
                        qrCode.download({
                            name: "bundle-qr",
                            extension: "png",
                        });
                    }
                });
            }
        </script>

        <script define:vars={{ bundleSlug }}>
            // Check if user owns this bundle
            const BUNDLES_KEY = "rsh_bundles";

            const getOwnedBundles = () => {
                try {
                    return JSON.parse(
                        localStorage.getItem(BUNDLES_KEY) || "{}",
                    );
                } catch {
                    return {};
                }
            };

            const ownedBundles = getOwnedBundles();

            if (ownedBundles[bundleSlug] && ownedBundles[bundleSlug].password) {
                // User owns this bundle - show edit button
                const editBtn = document.getElementById("edit-btn");
                if (editBtn) {
                    editBtn.classList.remove("hidden");
                }
            }
        </script>
    </body>
</html>
