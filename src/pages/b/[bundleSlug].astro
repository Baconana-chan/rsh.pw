---
import { getBundle, getBundleLinks } from "../../db/client";
import { ui, defaultLang } from "../../i18n/ui";
import SEO from "../../components/SEO.astro";

// Get the bundle slug from URL
const { bundleSlug } = Astro.params;
const bundle = bundleSlug ? getBundle(bundleSlug) : null;
const links = bundle ? getBundleLinks(bundleSlug) : [];

const lang = "en";
const t = ui[lang];

// Theme gradients (for icons and accents)
const themes: Record<string, string> = {
    purple: "from-cyan-500 to-teal-500",
    blue: "from-blue-600 to-cyan-600",
    green: "from-green-600 to-emerald-600",
    orange: "from-orange-600 to-red-600",
    pink: "from-amber-500 to-rose-500",
    dark: "from-gray-700 to-gray-900",
};

const themeGradient = bundle
    ? themes[bundle.theme] || themes.purple
    : themes.purple;

// Background styles
const bgStyles: Record<string, string> = {
    gradient: `bg-gradient-to-br ${themeGradient}`,
    solid: "bg-gray-900",
    dark: "bg-black",
    mesh: "bg-gray-900",
};

const bgStyle = bundle?.bg_style || "gradient";
const bgClass = bgStyles[bgStyle] || bgStyles.gradient;

// Card styles
const cardStyles: Record<string, string> = {
    glass: "bg-white/10 backdrop-blur-lg border border-white/20",
    solid: "bg-gray-800 border border-gray-700",
    outline: "bg-transparent border-2 border-gray-600",
    minimal: "bg-gray-800/30 border-0",
    neon: `bg-gray-900/80 border-2 border-cyan-500/50 shadow-lg shadow-cyan-500/20`,
};

const cardStyle = bundle?.card_style || "glass";
const cardClass = cardStyles[cardStyle] || cardStyles.glass;

// Button shape styles
const buttonStyles: Record<string, string> = {
    rounded: "rounded-xl",
    pill: "rounded-full",
    square: "rounded-lg",
    sharp: "rounded-none",
};

const buttonStyle = bundle?.button_style || "rounded";
const buttonClass = buttonStyles[buttonStyle] || buttonStyles.rounded;

// Extract username and platform from URL
const extractUsernameFromUrl = (
    url: string,
): { platform: string; username: string } | null => {
    try {
        const urlLower = url.toLowerCase();
        const urlObj = new URL(url);
        const pathname = urlObj.pathname;

        // Twitter/X: x.com/username or twitter.com/username
        if (urlLower.includes("x.com") || urlLower.includes("twitter.com")) {
            const match = pathname.match(/^\/([^\/]+)/);
            if (
                match &&
                match[1] &&
                ![
                    "home",
                    "explore",
                    "search",
                    "notifications",
                    "messages",
                    "settings",
                ].includes(match[1])
            ) {
                return { platform: "twitter", username: match[1] };
            }
        }

        // GitHub: github.com/username
        if (urlLower.includes("github.com")) {
            const match = pathname.match(/^\/([^\/]+)/);
            if (
                match &&
                match[1] &&
                ![
                    "features",
                    "marketplace",
                    "explore",
                    "settings",
                    "orgs",
                ].includes(match[1])
            ) {
                return { platform: "github", username: match[1] };
            }
        }

        // Instagram: instagram.com/username
        if (urlLower.includes("instagram.com")) {
            const match = pathname.match(/^\/([^\/]+)/);
            if (
                match &&
                match[1] &&
                !["p", "reel", "stories", "explore", "direct"].includes(
                    match[1],
                )
            ) {
                return { platform: "instagram", username: match[1] };
            }
        }

        // YouTube: youtube.com/@username
        if (urlLower.includes("youtube.com")) {
            const match = pathname.match(/^\/@?([^\/]+)/);
            if (match && match[1]) {
                return {
                    platform: "youtube",
                    username: match[1].replace("@", ""),
                };
            }
        }

        // Twitch: twitch.tv/username
        if (urlLower.includes("twitch.tv")) {
            const match = pathname.match(/^\/([^\/]+)/);
            if (
                match &&
                match[1] &&
                !["directory", "videos", "settings"].includes(match[1])
            ) {
                return { platform: "twitch", username: match[1] };
            }
        }

        // Telegram: t.me/username
        if (urlLower.includes("t.me")) {
            const match = pathname.match(/^\/([^\/]+)/);
            if (match && match[1]) {
                return { platform: "telegram", username: match[1] };
            }
        }
    } catch {
        return null;
    }
    return null;
};

// Get avatar URL from social media
const getAvatarUrl = (platform: string, username: string): string => {
    switch (platform) {
        case "github":
            return `https://github.com/${username}.png?size=200`;
        case "twitter":
            // Using unavatar.io for Twitter since direct access needs API
            return `https://unavatar.io/twitter/${username}`;
        case "instagram":
            return `https://unavatar.io/instagram/${username}`;
        case "youtube":
            return `https://unavatar.io/youtube/${username}`;
        case "twitch":
            return `https://unavatar.io/twitch/${username}`;
        case "telegram":
            return `https://unavatar.io/telegram/${username}`;
        default:
            return "";
    }
};

// Try to find an avatar from the links
let avatarUrl = "";
let avatarPlatform = "";
const priorityPlatforms = [
    "twitter",
    "github",
    "instagram",
    "youtube",
    "twitch",
    "telegram",
];

for (const platform of priorityPlatforms) {
    if (avatarUrl) break;
    for (const link of links) {
        const extracted = extractUsernameFromUrl(link.url);
        if (extracted && extracted.platform === platform) {
            avatarUrl = getAvatarUrl(extracted.platform, extracted.username);
            avatarPlatform = extracted.platform;
            break;
        }
    }
}

// List of known social media domains for which we have SVG icons
const knownSocialDomains = [
    "twitter.com",
    "x.com",
    "instagram.com",
    "youtube.com",
    "youtu.be",
    "tiktok.com",
    "github.com",
    "discord.com",
    "discord.gg",
    "twitch.tv",
    "telegram.org",
    "t.me",
    "linkedin.com",
    "facebook.com",
    "fb.com",
    "spotify.com",
    "pixiv.net",
    "nicovideo.jp",
    "nico.ms",
    "skeb.jp",
    "line.me",
    "vk.com",
    "reddit.com",
    "pinterest.com",
    "tumblr.com",
    "soundcloud.com",
    "behance.net",
    "dribbble.com",
    "deviantart.com",
    "artstation.com",
    "patreon.com",
    "ko-fi.com",
    "boosty.to",
    "fanbox.cc",
];

// Check if URL is a known social media
const isKnownSocial = (url: string): boolean => {
    const urlLower = url.toLowerCase();
    return knownSocialDomains.some((domain) => urlLower.includes(domain));
};

// Get favicon URL using Google's service
const getFaviconUrl = (url: string): string => {
    try {
        const hostname = new URL(url).hostname;
        return `https://www.google.com/s2/favicons?domain=${hostname}&sz=64`;
    } catch {
        return "";
    }
};

