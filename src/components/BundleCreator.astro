---
import { ui } from "../i18n/ui";
import {
    backgroundStyleOptions,
    buttonStyleOptions,
    cardStyleOptions,
    DEFAULT_BACKGROUND_STYLE,
    DEFAULT_BUTTON_STYLE,
    DEFAULT_CARD_STYLE,
    DEFAULT_THEME,
    themeOptions,
} from "../lib/bundle-options";
import SEO from "./SEO.astro";

const { lang = "en" } = Astro.props;
const t = ui[lang as keyof typeof ui];
---

<html lang={lang}>
    <head>
        <SEO
            title={`${t.create_bundle || "Create Link Bundle"} | rsh.pw`}
            description={t.bundle_subtitle ||
                "Create a collection of links like Linktree"}
        />
        <style>
            @keyframes gradient {
                0% {
                    background-position: 0% 50%;
                }
                50% {
                    background-position: 100% 50%;
                }
                100% {
                    background-position: 0% 50%;
                }
            }
            .animate-gradient {
                background-size: 200% 200%;
                animation: gradient 15s ease infinite;
            }
            .link-item:hover {
                border-color: rgba(139, 92, 246, 0.5);
            }
        </style>
    </head>
    <body
        class="bg-gray-900 text-white min-h-screen font-sans antialiased selection:bg-cyan-500 selection:text-white"
    >
        <!-- Header -->
        <div
            class="absolute top-4 left-4 right-4 flex justify-between items-center"
        >
            <div class="flex items-center gap-6">
                <a
                    href={lang === "ru" ? "/ru" : "/"}
                    class="text-gray-400 hover:text-white transition-colors flex items-center gap-2"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    <span class="text-sm hidden sm:inline">rsh.pw</span>
                </a>

                <div class="flex gap-3 text-sm text-gray-400">
                    <a
                        href="/bundle"
                        class={`hover:text-white transition-colors ${lang === "en" ? "text-white font-bold" : ""}`}
                        >EN</a
                    >
                    <a
                        href="/ru/bundle"
                        class={`hover:text-white transition-colors ${lang === "ru" ? "text-white font-bold" : ""}`}
                        >RU</a
                    >
                </div>
            </div>

            <button
                id="recovery-btn"
                class="text-sm text-gray-400 hover:text-white transition-colors"
            >
                {t.recover_bundle || "Recover Bundle"}
            </button>
        </div>

        <main
            class="w-full max-w-lg mx-auto px-6 py-20 flex flex-col items-center gap-8"
        >
            <!-- Title -->
            <div class="text-center space-y-2">
                <h1
                    class="text-4xl font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-cyan-300 to-teal-400 animate-gradient"
                >
                    {t.create_bundle || "Create Bundle"}
                </h1>
                <p class="text-gray-400 text-sm">
                    {
                        t.bundle_subtitle ||
                            "Create a collection of links like Linktree"
                    }
                </p>
            </div>

            <!-- Form -->
            <form
                id="bundle-form"
                class="w-full space-y-6 bg-gray-800/50 p-6 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-xl"
            >
                <!-- Bundle Title -->
                <div class="space-y-2">
                    <label class="text-sm text-gray-400"
                        >{t.bundle_title || "Bundle Title"} *</label
                    >
                    <input
                        type="text"
                        name="title"
                        required
                        placeholder={t.bundle_title_placeholder || "My Links"}
                        class="w-full bg-gray-900/50 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all"
                    />
                </div>

                <!-- Bundle Description -->
                <div class="space-y-2">
                    <label class="text-sm text-gray-400"
                        >{
                            t.bundle_description || "Description (optional)"
                        }</label
                    >
                    <textarea
                        name="description"
                        rows="2"
                        placeholder={t.bundle_description_placeholder ||
                            "A short description about yourself or your links"}
                        class="w-full bg-gray-900/50 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all resize-none"
                    ></textarea>
                </div>

                <!-- Custom Slug -->
                <div class="space-y-2">
                    <label class="text-sm text-gray-400"
                        >{
                            t.custom_bundle_slug || "Custom URL (optional)"
                        }</label
                    >
                    <div class="flex items-center gap-2">
                        <span class="text-gray-500 text-sm">rsh.pw/b/</span>
                        <input
                            type="text"
                            name="slug"
                            pattern="[a-zA-Z0-9-_]+"
                            placeholder={t.custom_slug_placeholder ||
                                "my-links"}
                            class="flex-1 bg-gray-900/50 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all text-sm"
                        />
                    </div>
                </div>

                <!-- Theme Selection -->
                <div class="space-y-2">
                    <label class="text-sm text-gray-400"
                        >{t.theme || "Color Theme"}</label
                    >
                    <div class="flex flex-wrap gap-2">
                        {
                            themeOptions.map((option) => (
                                <button
                                    type="button"
                                    data-theme={option.value}
                                    class={`theme-btn ${option.className} ${option.value === DEFAULT_THEME ? "active border-white" : ""}`}
                                ></button>
                            ))
                        }
                    </div>
                    <input type="hidden" name="theme" value={DEFAULT_THEME} />
                </div>

                <!-- Background Style -->
                <div class="space-y-2">
                    <label class="text-sm text-gray-400"
                        >{t.bg_style || "Background"}</label
                    >
                    <div class="flex flex-wrap gap-2">
                        {
                            backgroundStyleOptions.map((option) => (
                                <button
                                    type="button"
                                    data-bgstyle={option.value}
                                    class={`bgstyle-btn ${option.className} ${option.value === DEFAULT_BACKGROUND_STYLE ? "border-white" : ""}`}
                                >
                                    {t[option.labelKey as keyof typeof t] ||
                                        option.fallbackLabel}
                                </button>
                            ))
                        }
                    </div>
                    <input
                        type="hidden"
                        name="bgStyle"
                        value={DEFAULT_BACKGROUND_STYLE}
                    />
                </div>

                <!-- Card Style -->
                <div class="space-y-2">
                    <label class="text-sm text-gray-400"
                        >{t.card_style || "Card Style"}</label
                    >
                    <div class="flex flex-wrap gap-2">
                        {
                            cardStyleOptions.map((option) => (
                                <button
                                    type="button"
                                    data-cardstyle={option.value}
                                    class={`cardstyle-btn ${option.className} ${option.value === DEFAULT_CARD_STYLE ? "border-white" : ""}`}
                                >
                                    {t[option.labelKey as keyof typeof t] ||
                                        option.fallbackLabel}
                                </button>
                            ))
                        }
                    </div>
                    <input
                        type="hidden"
                        name="cardStyle"
                        value={DEFAULT_CARD_STYLE}
                    />
                </div>

                <!-- Button Shape -->
                <div class="space-y-2">
                    <label class="text-sm text-gray-400"
                        >{t.button_style || "Button Shape"}</label
                    >
                    <div class="flex flex-wrap gap-2">
                        {
                            buttonStyleOptions.map((option) => (
                                <button
                                    type="button"
                                    data-buttonstyle={option.value}
                                    class={`buttonstyle-btn ${option.className} ${option.value === DEFAULT_BUTTON_STYLE ? "border-white" : ""}`}
                                >
                                    {t[option.labelKey as keyof typeof t] ||
                                        option.fallbackLabel}
                                </button>
                            ))
                        }
                    </div>
                    <input
                        type="hidden"
                        name="buttonStyle"
                        value={DEFAULT_BUTTON_STYLE}
                    />
                </div>

                <!-- Links Section -->
                <div class="space-y-3">
                    <div class="flex justify-between items-center">
                        <label class="text-sm text-gray-400"
                            >{t.links || "Links"} *</label
                        >
                        <button
                            type="button"
                            id="add-link-btn"
                            class="text-sm text-cyan-400 hover:text-cyan-300 transition-colors flex items-center gap-1"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            {t.add_link || "Add Link"}
                        </button>
                    </div>

                    <!-- Quick Add Social Media -->
                    <div class="flex flex-wrap gap-1.5">
                        <button
                            type="button"
                            data-social="twitter"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                                ></path></svg
                            >
                            X
                        </button>
                        <button
                            type="button"
                            data-social="instagram"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                                ></path></svg
                            >
                            IG
                        </button>
                        <button
                            type="button"
                            data-social="youtube"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                                ></path></svg
                            >
                            YT
                        </button>
                        <button
                            type="button"
                            data-social="tiktok"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"
                                ></path></svg
                            >
                            TT
                        </button>
                        <button
                            type="button"
                            data-social="github"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                                ></path></svg
                            >
                            GH
                        </button>
                        <button
                            type="button"
                            data-social="twitch"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"
                                ></path></svg
                            >
                            TV
                        </button>
                        <button
                            type="button"
                            data-social="telegram"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
                                ></path></svg
                            >
                            TG
                        </button>
                        <button
                            type="button"
                            data-social="discord"
                            class="social-quick-btn px-2 py-1 text-xs rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                        >
                            <svg
                                class="w-3.5 h-3.5"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                ><path
                                    d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"
                                ></path></svg
                            >
                            DC
                        </button>
                    </div>

                    <div id="links-container" class="space-y-3">
                        <!-- Links will be added here -->
                    </div>
                </div>

                <!-- Submit Button -->
                <button
                    type="submit"
                    class="w-full bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-500 hover:to-teal-500 text-white font-bold py-3 px-6 rounded-xl transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-cyan-500/20"
                >
                    {t.create_bundle_btn || "Create Bundle"}
                </button>

                <!-- Error/Success Messages -->
                <div
                    id="error-msg"
                    class="hidden text-red-400 text-center text-sm"
                >
                </div>
            </form>
        </main>

        <!-- Success Modal -->
        <div
            id="success-modal"
            class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4 opacity-0 transition-opacity duration-300"
        >
            <div
                class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-md p-6 shadow-2xl transform scale-95 transition-transform duration-300"
                id="success-modal-content"
            >
                <div class="text-center space-y-4">
                    <div
                        class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-green-600 to-emerald-600 flex items-center justify-center"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="white"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>

                    <h2 class="text-xl font-bold text-white">
                        {t.bundle_created || "Bundle Created!"}
                    </h2>

                    <div class="space-y-3 text-left">
                        <div class="space-y-1">
                            <label class="text-xs text-gray-500"
                                >{t.your_bundle_url || "Your Bundle URL"}</label
                            >
                            <div
                                class="flex items-center gap-2 bg-gray-800 p-3 rounded-xl border border-gray-700"
                            >
                                <a
                                    id="bundle-url"
                                    href="#"
                                    target="_blank"
                                    class="flex-1 text-cyan-400 hover:text-cyan-300 truncate transition-colors text-sm"
                                ></a>
                                <button
                                    id="copy-url-btn"
                                    class="text-gray-400 hover:text-white p-1 rounded transition-colors"
                                    title="Copy"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        ><rect
                                            x="9"
                                            y="9"
                                            width="13"
                                            height="13"
                                            rx="2"
                                            ry="2"></rect><path
                                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                                        ></path></svg
                                    >
                                </button>
                            </div>
                        </div>

                        <div
                            class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 space-y-2"
                        >
                            <div
                                class="flex items-center gap-2 text-yellow-400 text-sm font-medium"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path
                                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
                                    ></path>
                                    <line x1="12" y1="9" x2="12" y2="13"></line>
                                    <line x1="12" y1="17" x2="12.01" y2="17"
                                    ></line>
                                </svg>
                                {t.save_password || "Save this password!"}
                            </div>
                            <p class="text-xs text-gray-400">
                                {
                                    t.password_warning ||
                                        "You will need this password to recover access if your browser data is cleared."
                                }
                            </p>
                            <div
                                class="flex items-center gap-2 bg-gray-800 p-2 rounded-lg"
                            >
                                <code
                                    id="recovery-password"
                                    class="flex-1 text-green-400 font-mono text-sm"
                                ></code>
                                <button
                                    id="copy-password-btn"
                                    class="text-gray-400 hover:text-white p-1 rounded transition-colors"
                                    title="Copy Password"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        ><rect
                                            x="9"
                                            y="9"
                                            width="13"
                                            height="13"
                                            rx="2"
                                            ry="2"></rect><path
                                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                                        ></path></svg
                                    >
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-3 pt-2">
                        <a
                            id="view-bundle-btn"
                            href="#"
                            class="flex-1 bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-500 hover:to-teal-500 text-white font-medium py-2 px-4 rounded-xl transition-all text-center text-sm"
                        >
                            {t.view_bundle || "View Bundle"}
                        </a>
                        <button
                            id="close-success-modal"
                            class="flex-1 bg-gray-800 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-xl transition-colors text-sm"
                        >
                            {t.close || "Close"}
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recovery Modal -->
        <div
            id="recovery-modal"
            class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4 opacity-0 transition-opacity duration-300"
        >
            <div
                class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-md p-6 shadow-2xl transform scale-95 transition-transform duration-300"
                id="recovery-modal-content"
            >
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-white">
                        {t.recover_bundle || "Recover Bundle"}
                    </h2>
                    <button
                        id="close-recovery-modal"
                        class="text-gray-400 hover:text-white transition-colors"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="18" y1="6" x2="6" y2="18"></line><line
                                x1="6"
                                y1="6"
                                x2="18"
                                y2="18"></line></svg
                        >
                    </button>
                </div>

                <form id="recovery-form" class="space-y-4">
                    <div class="space-y-2">
                        <label class="text-sm text-gray-400"
                            >{t.bundle_url_or_slug || "Bundle URL or Slug"} *</label
                        >
                        <input
                            type="text"
                            name="recovery-slug"
                            required
                            placeholder="rsh.pw/b/my-links or my-links"
                            class="w-full bg-gray-900/50 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all text-sm"
                        />
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm text-gray-400"
                            >{t.recovery_password_label || "Recovery Password"} *</label
                        >
                        <input
                            type="text"
                            name="recovery-password"
                            required
                            placeholder="alpha-beta-1234"
                            class="w-full bg-gray-900/50 border border-gray-700 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all font-mono text-sm"
                        />
                    </div>

                    <div
                        id="recovery-error"
                        class="hidden text-red-400 text-center text-sm"
                    >
                    </div>

                    <button
                        type="submit"
                        class="w-full bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-500 hover:to-teal-500 text-white font-bold py-3 px-6 rounded-xl transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-cyan-500/20"
                    >
                        {t.recover || "Recover"}
                    </button>
                </form>
            </div>
        </div>

        <script define:vars={{ t }}>
            // DOM Elements
            const form = document.getElementById("bundle-form");
            const linksContainer = document.getElementById("links-container");
            const addLinkBtn = document.getElementById("add-link-btn");
            const errorMsg = document.getElementById("error-msg");
            const themeBtns = document.querySelectorAll(".theme-btn");
            const themeInput = document.querySelector('input[name="theme"]');

            // Modals
            const successModal = document.getElementById("success-modal");
            const successModalContent = document.getElementById(
                "success-modal-content",
            );
            const closeSuccessModal = document.getElementById(
                "close-success-modal",
            );
            const bundleUrl = document.getElementById("bundle-url");
            const recoveryPassword =
                document.getElementById("recovery-password");
            const copyUrlBtn = document.getElementById("copy-url-btn");
            const copyPasswordBtn =
                document.getElementById("copy-password-btn");
            const viewBundleBtn = document.getElementById("view-bundle-btn");

            const recoveryBtn = document.getElementById("recovery-btn");
            const recoveryModal = document.getElementById("recovery-modal");
            const recoveryModalContent = document.getElementById(
                "recovery-modal-content",
            );
            const closeRecoveryModal = document.getElementById(
                "close-recovery-modal",
            );
            const recoveryForm = document.getElementById("recovery-form");
            const recoveryError = document.getElementById("recovery-error");

            // LocalStorage keys
            const BUNDLES_KEY = "rsh_bundles";

            // Get owned bundles from localStorage
            const getOwnedBundles = () => {
                try {
                    return JSON.parse(
                        localStorage.getItem(BUNDLES_KEY) || "{}",
                    );
                } catch {
                    return {};
                }
            };

            // Save bundle ownership to localStorage
            const saveOwnedBundle = (slug, password) => {
                const bundles = getOwnedBundles();
                bundles[slug] = { password, createdAt: Date.now() };
                localStorage.setItem(BUNDLES_KEY, JSON.stringify(bundles));
            };

            // Social media URL builders
            const socialPlatforms = {
                twitter: {
                    name: "X (Twitter)",
                    buildUrl: (username) =>
                        `https://x.com/${username.replace("@", "")}`,
                    placeholder: "@username",
                },
                instagram: {
                    name: "Instagram",
                    buildUrl: (username) =>
                        `https://instagram.com/${username.replace("@", "")}`,
                    placeholder: "@username",
                },
                youtube: {
                    name: "YouTube",
                    buildUrl: (channel) =>
                        channel.startsWith("@")
                            ? `https://youtube.com/${channel}`
                            : `https://youtube.com/@${channel}`,
                    placeholder: "@channel or channel name",
                },
                tiktok: {
                    name: "TikTok",
                    buildUrl: (username) =>
                        `https://tiktok.com/@${username.replace("@", "")}`,
                    placeholder: "@username",
                },
                github: {
                    name: "GitHub",
                    buildUrl: (username) =>
                        `https://github.com/${username.replace("@", "")}`,
                    placeholder: "username",
                },
                twitch: {
                    name: "Twitch",
                    buildUrl: (username) =>
                        `https://twitch.tv/${username.replace("@", "")}`,
                    placeholder: "username",
                },
                telegram: {
                    name: "Telegram",
                    buildUrl: (username) =>
                        `https://t.me/${username.replace("@", "")}`,
                    placeholder: "@username or username",
                },
                discord: {
                    name: "Discord",
                    buildUrl: (input) => {
                        // If it's a full URL, use it as is
                        if (input.startsWith("https://")) return input;
                        // If it looks like an invite code (no spaces, alphanumeric, usually 6-10 chars)
                        if (/^[a-zA-Z0-9]{4,12}$/.test(input))
                            return `https://discord.gg/${input}`;
                        // Otherwise treat as username - link to Discord profile
                        return `https://discord.com/users/${input.replace("@", "")}`;
                    },
                    placeholder: "username or invite code",
                },
            };

            // Link template with social media support
            const createLinkElement = (
                title = "",
                url = "",
                socialType = null,
            ) => {
                const div = document.createElement("div");
                div.className =
                    "link-item bg-gray-900/50 border border-gray-700 rounded-xl p-4 space-y-3 transition-colors";

                const isSmartInput = socialType !== null;
                const platform = socialType
                    ? socialPlatforms[socialType]
                    : null;

                div.innerHTML = `
          <div class="flex items-start gap-2">
            <!-- Move Buttons -->
            <div class="flex flex-col gap-1 pt-2 shrink-0">
                <button type="button" class="move-up-btn text-gray-600 hover:text-cyan-400 transition-colors" title="${t.move_up || "Move Up"}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
                </button>
                <button type="button" class="move-down-btn text-gray-600 hover:text-cyan-400 transition-colors" title="${t.move_down || "Move Down"}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
            </div>
            <div class="flex-1 space-y-3">
              <input 
                type="text" 
                name="link-title[]" 
                value="${title || (platform ? platform.name : "")}"
                required 
                placeholder="${t.link_title_placeholder || "Link Title"}"
                class="w-full bg-gray-800/50 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all text-sm"
              />
              ${
                  isSmartInput
                      ? `
                <div class="flex items-center gap-2">
                  <span class="text-gray-500 text-xs">${platform.name}:</span>
                  <input 
                    type="text" 
                    class="smart-input flex-1 bg-gray-800/50 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all text-sm"
                    placeholder="${platform.placeholder}"
                    data-platform="${socialType}"
                  />
                </div>
                <input 
                  type="hidden" 
                  name="link-url[]" 
                  value="${url}"
                />
              `
                      : `
                <input 
                  type="url" 
                  name="link-url[]" 
                  value="${url}"
                  required 
                  placeholder="${t.link_url_placeholder || "https://example.com or @username"}"
                  class="url-input w-full bg-gray-800/50 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:border-cyan-500 transition-all text-sm"
                />
              `
              }
              <div class="flex items-center gap-2 px-1">
                  <label class="relative inline-flex items-center cursor-pointer">
                      <input type="checkbox" name="link-highlight[]" class="sr-only peer">
                      <div class="w-7 h-4 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-cyan-600"></div>
                  </label>
                  <span class="text-xs text-gray-500" title="${t.highlight_desc || "Make this link stand out"}">${t.highlight || "Highlight"}</span>
              </div>
            </div>
            <button type="button" class="remove-link-btn text-gray-500 hover:text-red-400 p-2 transition-colors" title="Remove">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        `;

                div.querySelector(".remove-link-btn").addEventListener(
                    "click",
                    () => {
                        div.remove();
                    },
                );

                div.querySelector(".move-up-btn").addEventListener(
                    "click",
                    () => {
                        const prev = div.previousElementSibling;
                        if (prev) {
                            div.parentElement.insertBefore(div, prev);
                        }
                    },
                );

                div.querySelector(".move-down-btn").addEventListener(
                    "click",
                    () => {
                        const next = div.nextElementSibling;
                        if (next) {
                            div.parentElement.insertBefore(next, div);
                        }
                    },
                );

                // Handle smart input for social media
                const smartInput = div.querySelector(".smart-input");
                if (smartInput) {
                    const hiddenUrl = div.querySelector(
                        'input[name="link-url[]"]',
                    );
                    smartInput.addEventListener("input", (e) => {
                        const value = e.target.value.trim();
                        const platformType = e.target.dataset.platform;
                        if (value && socialPlatforms[platformType]) {
                            hiddenUrl.value =
                                socialPlatforms[platformType].buildUrl(value);
                        } else {
                            hiddenUrl.value = "";
                        }
                    });
                }

                // Handle URL input - auto-detect @username patterns
                const urlInput = div.querySelector(".url-input");
                if (urlInput) {
                    urlInput.addEventListener("blur", (e) => {
                        const value = e.target.value.trim();
                        // Auto-convert @username patterns
                        if (
                            value.startsWith("@") &&
                            !value.includes(" ") &&
                            !value.includes("/")
                        ) {
                            // Assume Twitter/X for plain @username
                            e.target.value = `https://x.com/${value.replace("@", "")}`;
                        }
                    });
                }

                return div;
            };

            // Add initial link
            linksContainer.appendChild(createLinkElement());

            // Add link button
            addLinkBtn.addEventListener("click", () => {
                linksContainer.appendChild(createLinkElement());
            });

            // Social quick add buttons
            const socialQuickBtns =
                document.querySelectorAll(".social-quick-btn");
            socialQuickBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const platform = btn.dataset.social;
                    linksContainer.appendChild(
                        createLinkElement("", "", platform),
                    );
                    // Focus the smart input
                    const lastItem = linksContainer.lastElementChild;
                    const smartInput = lastItem.querySelector(".smart-input");
                    if (smartInput) {
                        smartInput.focus();
                    }
                });
            });

            // Theme selection
            themeBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    themeBtns.forEach((b) =>
                        b.classList.remove("active", "border-white"),
                    );
                    btn.classList.add("active", "border-white");
                    themeInput.value = btn.dataset.theme;
                });
            });

            // Theme/Style handlers
            const setupStyleSelector = (
                btnClass,
                inputName,
                activeClass = "border-white",
            ) => {
                const btns = document.querySelectorAll(`.${btnClass}`);
                const input = document.querySelector(
                    `input[name="${inputName}"]`,
                );

                if (!btns.length || !input) return;

                btns.forEach((btn) => {
                    btn.addEventListener("click", () => {
                        btns.forEach((b) => {
                            if (activeClass.includes("border-")) {
                                // For color themes
                                b.classList.remove("active", "border-white");
                                b.classList.add("border-transparent");
                            } else {
                                // For other styles
                                b.classList.remove("border-white");
                                b.classList.add(
                                    b.classList.contains("bg-white/10")
                                        ? "border-white"
                                        : "border-transparent",
                                );
                                // Reset specialized borders
                                if (b.dataset.cardstyle === "outline")
                                    b.classList.remove(
                                        "border-white",
                                        "border-gray-600",
                                    );
                                if (b.dataset.cardstyle === "outline")
                                    b.classList.add("border-gray-600");
                            }
                        });

                        // Set active state
                        if (activeClass.includes("border-")) {
                            btn.classList.add("active", "border-white");
                            btn.classList.remove("border-transparent");
                        } else {
                            // Simplify: just remove transparent border and add white border for selection
                            // except for outline/neon styles that handle their own borders
                        }

                        // Simple active state management for all style buttons
                        btns.forEach((b) => {
                            b.classList.remove(
                                "ring-2",
                                "ring-offset-2",
                                "ring-cyan-500",
                                "ring-offset-gray-900",
                            );
                        });
                        btn.classList.add(
                            "ring-2",
                            "ring-offset-2",
                            "ring-cyan-500",
                            "ring-offset-gray-900",
                        );

                        input.value = btn.dataset[inputName.toLowerCase()];
                    });
                });

                // Set initial active state correctly
                const initialBtn = document.querySelector(
                    `.${btnClass}[data-${inputName.toLowerCase()}="${input.value}"]`,
                );
                if (initialBtn) {
                    initialBtn.classList.add(
                        "ring-2",
                        "ring-offset-2",
                        "ring-cyan-500",
                        "ring-offset-gray-900",
                    );
                }
            };

            // Initialize selectors
            // themeBtns logic is replaced by the generalized one above, but we keep existing specific logic for themes if preferred,
            // or we use the new one. To avoid conflict with existing theme code, we'll just add new ones.

            // Background Style
            const bgStyleBtns = document.querySelectorAll(".bgstyle-btn");
            const bgStyleInput = document.querySelector(
                'input[name="bgStyle"]',
            );
            bgStyleBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    bgStyleBtns.forEach((b) =>
                        b.classList.remove(
                            "ring-2",
                            "ring-offset-2",
                            "ring-cyan-500",
                            "ring-offset-gray-900",
                        ),
                    );
                    btn.classList.add(
                        "ring-2",
                        "ring-offset-2",
                        "ring-cyan-500",
                        "ring-offset-gray-900",
                    );
                    bgStyleInput.value = btn.dataset.bgstyle;
                });
            });
            // Set initial
            if (bgStyleBtns.length > 0)
                bgStyleBtns[0].classList.add(
                    "ring-2",
                    "ring-offset-2",
                    "ring-cyan-500",
                    "ring-offset-gray-900",
                );

            // Card Style
            const cardStyleBtns = document.querySelectorAll(".cardstyle-btn");
            const cardStyleInput = document.querySelector(
                'input[name="cardStyle"]',
            );
            cardStyleBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    cardStyleBtns.forEach((b) =>
                        b.classList.remove(
                            "ring-2",
                            "ring-offset-2",
                            "ring-cyan-500",
                            "ring-offset-gray-900",
                        ),
                    );
                    btn.classList.add(
                        "ring-2",
                        "ring-offset-2",
                        "ring-cyan-500",
                        "ring-offset-gray-900",
                    );
                    cardStyleInput.value = btn.dataset.cardstyle;
                });
            });
            if (cardStyleBtns.length > 0)
                cardStyleBtns[0].classList.add(
                    "ring-2",
                    "ring-offset-2",
                    "ring-cyan-500",
                    "ring-offset-gray-900",
                );

            // Button Style
            const buttonStyleBtns =
                document.querySelectorAll(".buttonstyle-btn");
            const buttonStyleInput = document.querySelector(
                'input[name="buttonStyle"]',
            );
            buttonStyleBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    buttonStyleBtns.forEach((b) =>
                        b.classList.remove(
                            "ring-2",
                            "ring-offset-2",
                            "ring-cyan-500",
                            "ring-offset-gray-900",
                        ),
                    );
                    btn.classList.add(
                        "ring-2",
                        "ring-offset-2",
                        "ring-cyan-500",
                        "ring-offset-gray-900",
                    );
                    buttonStyleInput.value = btn.dataset.buttonstyle;
                });
            });
            if (buttonStyleBtns.length > 0)
                buttonStyleBtns[0].classList.add(
                    "ring-2",
                    "ring-offset-2",
                    "ring-cyan-500",
                    "ring-offset-gray-900",
                );

            // Modal helpers
            const openModal = (modal, content) => {
                modal.classList.remove("hidden");
                setTimeout(() => {
                    modal.classList.remove("opacity-0");
                    content.classList.remove("scale-95");
                    content.classList.add("scale-100");
                }, 10);
            };

            const closeModalFunc = (modal, content) => {
                modal.classList.add("opacity-0");
                content.classList.remove("scale-100");
                content.classList.add("scale-95");
                setTimeout(() => {
                    modal.classList.add("hidden");
                }, 300);
            };

            // Copy helper
            const copyToClipboard = (text, btn) => {
                navigator.clipboard.writeText(text).then(() => {
                    const originalSvg = btn.innerHTML;
                    btn.innerHTML =
                        '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                    btn.classList.add("text-green-400");
                    setTimeout(() => {
                        btn.innerHTML = originalSvg;
                        btn.classList.remove("text-green-400");
                    }, 2000);
                });
            };

            // Form submission
            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                errorMsg.classList.add("hidden");

                const formData = new FormData(form);
                const title = formData.get("title");
                const description = formData.get("description");
                const customSlug = formData.get("slug");
                const theme = formData.get("theme");
                const bgStyle = formData.get("bgStyle");
                const cardStyle = formData.get("cardStyle");
                const buttonStyle = formData.get("buttonStyle");

                // Get links
                const linkElements =
                    linksContainer.querySelectorAll(".link-item");
                const links = Array.from(linkElements)
                    .map((el) => {
                        const title = el.querySelector(
                            'input[name="link-title[]"]',
                        ).value;
                        const url = el.querySelector(
                            'input[name="link-url[]"]',
                        ).value;
                        const isHighlighted = el.querySelector(
                            'input[name="link-highlight[]"]',
                        ).checked;
                        return { title, url, isHighlighted };
                    })
                    .filter((l) => l.title && l.url);

                if (links.length === 0) {
                    errorMsg.textContent =
                        t.at_least_one_link || "Please add at least one link";
                    errorMsg.classList.remove("hidden");
                    return;
                }

                try {
                    const res = await fetch("/api/bundle", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            title: title.trim(),
                            description: description?.trim(),
                            customSlug: customSlug?.trim(),
                            theme,
                            bgStyle,
                            cardStyle,
                            buttonStyle,
                            links,
                        }),
                    });

                    const data = await res.json();

                    if (!res.ok) {
                        throw new Error(
                            data.error || t.error || "Something went wrong",
                        );
                    }

                    // Save ownership to localStorage
                    saveOwnedBundle(data.slug, data.recoveryPassword);

                    // Show success modal
                    const fullUrl = `${window.location.origin}/b/${data.slug}`;
                    bundleUrl.href = fullUrl;
                    bundleUrl.textContent = fullUrl;
                    recoveryPassword.textContent = data.recoveryPassword;
                    viewBundleBtn.href = fullUrl;

                    openModal(successModal, successModalContent);
                    form.reset();
                    linksContainer.innerHTML = "";
                    linksContainer.appendChild(createLinkElement());

                    // Reset theme
                    themeBtns.forEach((b) =>
                        b.classList.remove("active", "border-white"),
                    );
                    themeBtns[0].classList.add("active", "border-white");
                    themeInput.value = "blue";
                } catch (err) {
                    errorMsg.textContent = err.message;
                    errorMsg.classList.remove("hidden");
                }
            });

            // Success modal events
            closeSuccessModal.addEventListener("click", () =>
                closeModalFunc(successModal, successModalContent),
            );
            successModal.addEventListener("click", (e) => {
                if (e.target === successModal)
                    closeModalFunc(successModal, successModalContent);
            });

            copyUrlBtn.addEventListener("click", () =>
                copyToClipboard(bundleUrl.textContent, copyUrlBtn),
            );
            copyPasswordBtn.addEventListener("click", () =>
                copyToClipboard(recoveryPassword.textContent, copyPasswordBtn),
            );

            // Recovery modal
            recoveryBtn.addEventListener("click", () =>
                openModal(recoveryModal, recoveryModalContent),
            );
            closeRecoveryModal.addEventListener("click", () =>
                closeModalFunc(recoveryModal, recoveryModalContent),
            );
            recoveryModal.addEventListener("click", (e) => {
                if (e.target === recoveryModal)
                    closeModalFunc(recoveryModal, recoveryModalContent);
            });

            // Recovery form
            recoveryForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                recoveryError.classList.add("hidden");

                const formData = new FormData(recoveryForm);
                let slug = formData.get("recovery-slug").trim();
                const password = formData.get("recovery-password").trim();

                // Extract slug from URL if full URL provided
                if (slug.includes("/b/")) {
                    slug = slug.split("/b/").pop();
                }
                if (slug.includes("/")) {
                    slug = slug.split("/").pop();
                }

                try {
                    const res = await fetch("/api/bundle-verify", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ slug, password }),
                    });

                    const data = await res.json();

                    if (!res.ok) {
                        throw new Error(
                            data.error || t.error || "Something went wrong",
                        );
                    }

                    // Save ownership to localStorage
                    saveOwnedBundle(slug, password);

                    // Close modal and redirect to edit page
                    closeModalFunc(recoveryModal, recoveryModalContent);
                    window.location.href = `/b/${slug}/edit`;
                } catch (err) {
                    recoveryError.textContent = err.message;
                    recoveryError.classList.remove("hidden");
                }
            });

            // Set initial theme button active state
            document
                .querySelector('.theme-btn[data-theme="blue"]')
                .classList.add("border-white");
        </script>
    </body>
</html>
